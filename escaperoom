        /* ==================================================
           ESTADO DEL JUEGO
           ================================================== */
        let currentQuestion = 0;
        let score = 0;
        let streak = 0;
        let maxStreak = 0;
        let correctCount = 0;
        let lives = 3;
        
        let timerInterval;
        let timeLeft = 0;
        let totalTime = 0;
        
        let deathReason = "";
        let deathQNum = 0;

        /* ==================================================
           LÓGICA PRINCIPAL
           ================================================== */
        
        function showScreen(screenId) {
            document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
            document.getElementById(screenId).classList.add('active');
        }

        function initGame() {
            currentQuestion = 0;
            score = 0;
            streak = 0;
            maxStreak = 0;
            correctCount = 0;
            lives = 3;
            updateMetrics();
            updateLivesUI();
            
            // Reset animaciones derrota/victoria
            document.getElementById('tomb').classList.remove('animate');
            document.getElementById('worm').classList.remove('animate');
            document.getElementById('rip-title').classList.remove('animate');
            document.getElementById('victory-trophy').classList.remove('animate');
            
            showScreen('screen-start');
        }

        function startGame() {
            showScreen('screen-game');
            loadQuestion();
        }

        function loadQuestion() {
            // Reset UI
            document.getElementById('btn-next').classList.remove('show');
            document.getElementById('feedback-box').classList.remove('show');
            
            const q = questionsData[currentQuestion];
            
            // Textos
            document.getElementById('q-number').textContent = `Pregunta ${currentQuestion + 1} de 15`;
            document.getElementById('q-badge').textContent = q.badge;
            document.getElementById('q-narrative').textContent = q.narrative;
            document.getElementById('q-text').textContent = q.text;
            
            // Barra de progreso
            const progress = (currentQuestion / 15) * 100;
            document.getElementById('progress-bar').style.width = `${progress}%`;
            
            // Opciones
            const optionsContainer = document.getElementById('options-container');
            optionsContainer.innerHTML = '';
            q.options.forEach((opt, index) => {
                const btn = document.createElement('button');
                btn.className = 'option-btn';
                btn.textContent = `${String.fromCharCode(65 + index)}) ${opt}`;
                btn.onclick = () => handleAnswer(index);
                optionsContainer.appendChild(btn);
            });

            startTimer(q.time);
        }

        function startTimer(seconds) {
            clearInterval(timerInterval);
            totalTime = seconds;
            timeLeft = seconds;
            updateTimerUI();

            timerInterval = setInterval(() => {
                timeLeft--;
                updateTimerUI();
                if (timeLeft <= 0) {
                    clearInterval(timerInterval);
                    handleTimeout();
                }
            }, 1000);
        }

        function updateTimerUI() {
            const bar = document.getElementById('timer-bar');
            const text = document.getElementById('timer-text');
            const pct = (timeLeft / totalTime) * 100;
            
            bar.style.width = `${pct}%`;
            text.textContent = `${timeLeft}s`;
            
            // Colores
            if (pct > 50) {
                bar.style.backgroundColor = 'var(--accent-cyan)';
            } else if (pct > 25) {
                bar.style.backgroundColor = 'var(--warning-color)';
            } else {
                bar.style.backgroundColor = 'var(--wrong-color)';
            }

            if (timeLeft <= 5 && timeLeft > 0) {
                text.classList.add('blink');
            } else {
                text.classList.remove('blink');
            }
        }

        function stopTimer() {
            clearInterval(timerInterval);
            document.getElementById('timer-text').classList.remove('blink');
        }

        function handleAnswer(selectedIndex) {
            stopTimer();
            const q = questionsData[currentQuestion];
            const isCorrect = (selectedIndex === q.correctIndex);
            
            if (isCorrect) {
                streak++;
                if (streak > maxStreak) maxStreak = streak;
                
                let pointsGained = 10;
                if (streak === 2) pointsGained += 10;
                if (streak >= 3) pointsGained += 20;
                score += pointsGained;
                correctCount++;
                
                processFeedback(isCorrect, selectedIndex);
            } else {
                streak = 0;
                lives--;
                deathReason = "respuesta incorrecta";
                deathQNum = currentQuestion + 1;
                
                showScareOverlay("wrong", () => {
                    processFeedback(isCorrect, selectedIndex);
                });
            }
        }

        function handleTimeout() {
            streak = 0;
            lives--;
            deathReason = "tiempo agotado";
            deathQNum = currentQuestion + 1;
            
            showScareOverlay("timeout", () => {
                processFeedback(false, -1);
            });
        }

        function processFeedback(isCorrect, selectedIndex) {
            updateMetrics();
            updateLivesUI();
            
            const q = questionsData[currentQuestion];
            const btns = document.querySelectorAll('.option-btn');
            
            // Deshabilitar y colorear
            btns.forEach((btn, idx) => {
                btn.disabled = true;
                if (idx === q.correctIndex) {
                    btn.classList.add('correct');
                    if (selectedIndex === -1) btn.classList.add('was-correct'); // Timeout
                } else if (idx === selectedIndex) {
                    btn.classList.add('wrong');
                }
            });

            // Caja de feedback
            const fbBox = document.getElementById('feedback-box');
            const fbTitle = document.getElementById('feedback-title');
            const fbText = document.getElementById('feedback-text');
            
            fbBox.className = 'feedback-box show';
            if (isCorrect) {
                fbBox.classList.add('success');
                fbTitle.textContent = '✓ Correcto';
                fbTitle.style.color = 'var(--correct-color)';
                fbText.textContent = q.feedbackCorrect;
            } else {
                fbBox.classList.add('error');
                fbTitle.textContent = selectedIndex === -1 ? '⌛ Tiempo Agotado' : '✗ Incorrecto';
                fbTitle.style.color = 'var(--wrong-color)';
                fbText.textContent = q.feedbackWrong;
            }

            // Botón siguiente
            const btnNext = document.getElementById('btn-next');
            if (lives <= 0 || currentQuestion === 14) {
                btnNext.textContent = "Ver resultado final &rarr;";
            } else {
                btnNext.textContent = "Siguiente decisión &rarr;";
            }
            btnNext.classList.add('show');
        }

        function nextAction() {
            if (lives <= 0) {
                showDefeat();
            } else if (currentQuestion === 14) {
                showVictory();
            } else {
                currentQuestion++;
                loadQuestion();
            }
        }

        /* ==================================================
           EFECTOS Y ACTUALIZACIONES DE UI
           ================================================== */
        
        function updateMetrics() {
            document.getElementById('metric-q').textContent = `${currentQuestion + 1}/15`;
            document.getElementById('metric-score').textContent = score;
            document.getElementById('metric-streak').textContent = streak;
        }

        function updateLivesUI() {
            const statusText = document.getElementById('lives-text');
            for (let i = 1; i <= 3; i++) {
                const circle = document.getElementById(`life-${i}`);
                if (i <= lives) circle.classList.remove('lost');
                else circle.classList.add('lost');
            }
            
            if (lives === 3) {
                statusText.textContent = "Empresa saludable";
                statusText.style.color = "var(--text-main)";
            } else if (lives === 2) {
                statusText.textContent = "Bajo presión";
                statusText.style.color = "var(--warning-color)";
            } else if (lives === 1) {
                statusText.textContent = "Al borde del colapso";
                statusText.style.color = "var(--wrong-color)";
            } else {
                statusText.textContent = "Bancarrota";
                statusText.style.color = "#475569";
            }
        }

        function showScareOverlay(reason, callback) {
            const overlay = document.getElementById('scare-overlay');
            const icon = document.getElementById('scare-icon');
            const title = document.getElementById('scare-title');
            const subtitle = document.getElementById('scare-subtitle');
            
            if (lives === 2) {
                if (reason === 'wrong') {
                    icon.textContent = '💀';
                    title.textContent = '¡VIDA PERDIDA!';
                    subtitle.textContent = 'NovaTech sangra. Dos chances más.';
                } else {
                    icon.textContent = '⏰';
                    title.textContent = '¡SE ACABÓ EL TIEMPO!';
                    subtitle.textContent = 'El mercado no espera. Perdiste una vida.';
                }
            } else if (lives === 1) {
                if (reason === 'wrong') {
                    icon.textContent = '🔥';
                    title.textContent = '¡LA EMPRESA SE QUEMA!';
                    subtitle.textContent = 'Solo te queda una vida. No hay margen.';
                } else {
                    icon.textContent = '⌛';
                    title.textContent = '¡TIEMPO AGOTADO!';
                    subtitle.textContent = 'Última oportunidad. El directorio te observa.';
                }
            } else {
                icon.textContent = '💥';
                title.textContent = '¡COLAPSO TOTAL!';
                subtitle.textContent = 'NovaTech ha quebrado.';
            }

            overlay.classList.add('show');
            setTimeout(() => {
                overlay.classList.remove('show');
                if(callback) callback();
            }, 1400);
        }

        function showDefeat() {
            showScreen('screen-defeat');
            document.getElementById('defeat-score').textContent = score;
            document.getElementById('defeat-correct').textContent = `${correctCount}/15`;
            document.getElementById('defeat-subtitle').textContent = `La empresa quebró en la pregunta ${deathQNum} por ${deathReason}.`;
            
            setTimeout(() => document.getElementById('tomb').classList.add('animate'), 100);
            setTimeout(() => document.getElementById('worm').classList.add('animate'), 100);
            setTimeout(() => document.getElementById('rip-title').classList.add('animate'), 100);
        }

        function showVictory() {
            showScreen('screen-victory');
            document.getElementById('victory-score').textContent = score;
            document.getElementById('victory-correct').textContent = `${correctCount}/15`;
            document.getElementById('victory-streak').textContent = maxStreak;
            
            const pct = (correctCount / 15) * 100;
            const titleEl = document.getElementById('victory-title');
            const msgEl = document.getElementById('victory-msg');
            const descEl = document.getElementById('victory-desc');
            const trophyEl = document.getElementById('victory-trophy');
            
            setTimeout(() => trophyEl.classList.add('animate'), 100);

            if (pct >= 90) {
                titleEl.textContent = "NovaTech es una ExO";
                trophyEl.textContent = "🏆";
                msgEl.textContent = "Superaste la crisis con excelencia.";
                descEl.textContent = "Demostraste comprensión profunda de la lógica exponencial. Entendés que el mundo cambió de naturaleza y que la única respuesta válida es un modelo completamente distinto. Ismail estaría orgulloso.";
            } else if (pct >= 70) {
                titleEl.textContent = "NovaTech sobrevivió";
                trophyEl.textContent = "🎯";
                titleEl.style.color = "var(--warning-color)";
                msgEl.textContent = "Evitaste la quiebra, pero hay trabajo por hacer.";
                descEl.textContent = "Manejaste bien los conceptos fundamentales. Algunas tensiones internas quedaron sin resolver, pero la dirección es la correcta. Con más práctica, la transformación completa es posible.";
            } else {
                titleEl.textContent = "NovaTech resistió, por ahora";
                trophyEl.textContent = "🌱";
                titleEl.style.color = "var(--accent-orange)";
                msgEl.textContent = "Sobreviviste raspando. El mercado sigue acechando.";
                descEl.textContent = "Entendés los conceptos pero la aplicación al caso concreto todavía tiene margen de crecimiento. La próxima disrupción va a requerir más velocidad y más profundidad de análisis.";
            }
        }

        // Iniciar
        window.onload = initGame;
    </script>
